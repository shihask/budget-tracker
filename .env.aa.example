# Setu Bridge sandbox credentials — see README.md for how to obtain these.
# Copy this file to .env.aa (git-ignored) and fill in real values.
SETU_BASE_URL=https://fiu-sandbox.setu.co
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=

# Local port for the webhook listener (02-webhook-server.mjs). Point your
# tunnel (e.g. ngrok) at this port and register the tunnel's HTTPS URL with
# Setu Bridge as the notification endpoint.
AA_WEBHOOK_PORT=8787

# A sandbox test user's virtual address (VUA), e.g. 9999999999@setu-fiu-sandbox
# — Setu Bridge's sandbox docs list the available mock test users/banks.
AA_TEST_VUA=
